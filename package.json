{
  "name": "vibe-coding-assistant",
  "displayName": "Vibe Coding Assistant",
  "description": "AI coding assistant with file editing tools",
  "version": "0.4.0",
  "publisher": "DoubtedSteam",
  "repository": {
    "type": "git",
    "url": "https://github.com/DoubtedSteam/OpenVibe.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:vibeCodingChat"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vibe-coding",
          "title": "Vibe Coding",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "vibe-coding": [
        {
          "id": "vibeCodingChat",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "vibe-coding.openChat",
        "title": "Open Vibe Coding Chat"
      },
      {
        "command": "vibe-coding.clearHistory",
        "title": "Clear Chat History"
      }
    ],
    "configuration": {
      "title": "Vibe Coding Assistant",
      "properties": {
        "vibe-coding.apiBaseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "Base URL for OpenAI-compatible API"
        },
        "vibe-coding.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key"
        },
        "vibe-coding.model": {
          "type": "string",
          "default": "deepseek-reasoner",
          "description": "Model name"
        },
        "vibe-coding.confirmChanges": {
          "type": "boolean",
          "default": true,
          "description": "Whether to ask for confirmation before applying file changes"
        },
        "vibe-coding.maxInteractions": {
          "type": "number",
          "default": -1,
          "description": "Maximum number of tool call iterations (-1 means unlimited)"
        },
        "vibe-coding.maxSequenceLength": {
          "type": "number",
          "default": 1000000,
          "description": "Maximum length for generated text sequences"
        },
        "vibe-coding.todolistReview.enabled": {
          "type": "boolean",
          "default": true,
          "description": "When true, create_todo_list runs a blocking independent LLM review for todolist.generate / todolist.edit before applying changes."
        },
        "vibe-coding.todolistReview.maxAttempts": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Max review/regenerate rounds per create_todo_list call (generate or expand)."
        },
        "vibe-coding.todolistReview.reviewTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 5000,
          "description": "HTTP timeout (ms) for each review-agent and regenerate (generate) API call."
        },
        "vibe-coding.todolistReview.editorTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 5000,
          "description": "HTTP timeout (ms) for each editor-agent API call (todolist.edit expand retries)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "18.x",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}